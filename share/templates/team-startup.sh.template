#!/bin/zsh
# {{TEAM_NAME}} Startup Script
# Auto-generated by aiteamforge installer
# Launches LCARS kanban server and opens iTerm2 tabs for the team

# ============================================================================
# Configuration
# ============================================================================
TEAM_ID="{{TEAM_ID}}"
TEAM_NAME="{{TEAM_NAME}}"
TEAM_THEME="{{TEAM_THEME}}"
AITEAMFORGE_DIR="{{AITEAMFORGE_DIR}}"
TEAM_WORKING_DIR="{{TEAM_WORKING_DIR}}"
TMUX_SOCKET="{{TEAM_TMUX_SOCKET}}"
LCARS_PORT="{{TEAM_LCARS_PORT}}"
ITERM_WINDOW_NAME="${TEAM_NAME}"
ITERM_STARTUP_LOG="/tmp/${TEAM_ID}-startup-iterm2-$(date +%Y%m%d-%H%M%S).log"
AGENTS=({{TEAM_TERMINAL_LIST}})

# Per-agent tmux window names (populated by installer from team conf AGENT_WINDOWS_* variables)
# Format: "win0 win1 win2 win3" — used when creating tmux sessions
{{TEAM_AGENT_WINDOWS_CONFIG}}

# Resolve kanban dir
if [[ -n "$TEAM_WORKING_DIR" && "$TEAM_WORKING_DIR" != "$AITEAMFORGE_DIR" && "$TEAM_WORKING_DIR" != "$AITEAMFORGE_DIR/$TEAM_ID" ]]; then
    KANBAN_DIR="${TEAM_WORKING_DIR}/kanban"
else
    KANBAN_DIR="${AITEAMFORGE_DIR}/kanban"
fi

# Warn about unexpected arguments
if [[ $# -gt 0 ]]; then
    echo "Note: This startup script takes no arguments (got: $*)"
    echo "      Configuration is built-in from aiteamforge setup."
    echo ""
fi

# ============================================================================
# Cleanup orphaned processes from previous crashed sessions
# ============================================================================
# Kill stale zsh processes that have no controlling terminal and were
# reparented to init/launchd (PID 1) — typically left by crashed tmux sessions.
#
# Scope: only kills orphans whose cwd is under AITEAMFORGE_DIR or TEAM_WORKING_DIR,
# avoiding collateral damage to unrelated zsh sessions on the system.
cleanup_orphans() {
    local orphans orphan_pids=() pid cwd_line

    # Gather candidate pids: zsh, no tty, ppid==1
    orphans=$(ps -eo pid,ppid,tty,comm | awk '$4 == "zsh" && $3 == "??" && $2 == 1 {print $1}')

    if [[ -n "$orphans" ]]; then
        while IFS= read -r pid; do
            [[ -z "$pid" ]] && continue
            # Confirm the orphan belongs to this team by checking its cwd.
            # Only kill if cwd is under our AITEAMFORGE_DIR or TEAM_WORKING_DIR.
            cwd_line=$(lsof -p "$pid" 2>/dev/null | awk '$4 == "cwd" {print $NF}')
            if [[ -n "$cwd_line" ]]; then
                if [[ "$cwd_line" == "${AITEAMFORGE_DIR}"* || "$cwd_line" == "${TEAM_WORKING_DIR}"* ]]; then
                    orphan_pids+=("$pid")
                fi
            fi
        done <<< "$orphans"
    fi

    if [[ ${#orphan_pids[@]} -gt 0 ]]; then
        echo "  Cleaning up ${#orphan_pids[@]} orphaned team process(es)..."
        kill "${orphan_pids[@]}" 2>/dev/null || true
    fi

    # Kill any stale LCARS server processes on THIS team's port only.
    # The port is team-specific so this cannot affect other teams' servers.
    if pkill -f "server\.py ${LCARS_PORT}$" 2>/dev/null; then
        echo "  Cleaned up stale LCARS server on port ${LCARS_PORT}"
    fi
}

# ============================================================================
# Pre-flight checks
# ============================================================================
PREFLIGHT_ERRORS=0

preflight_check() {
    local name="$1" cmd="$2" fix="$3"
    if ! command -v "$cmd" &>/dev/null; then
        echo "  ✗ $name not found"
        echo "    Fix: $fix"
        PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
    fi
}

preflight_check "python3" "python3" "brew install python@3"

if [[ ! -d "/Applications/iTerm.app" ]]; then
    echo "  ✗ iTerm2 not found"
    echo "    Fix: brew install --cask iterm2"
    PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
fi

if [[ -d "/Applications/iTerm.app" ]]; then
    _api=$(defaults read com.googlecode.iterm2 EnableAPIServer 2>/dev/null || true)
    if [[ "$_api" != "1" ]]; then
        echo "  Enabling iTerm2 Python API..."
        defaults write com.googlecode.iterm2 EnableAPIServer -bool true
        echo "  ⚠ iTerm2 must be restarted for Python API to activate."
        echo "    Please quit and restart iTerm2, then run this script again."
        exit 1
    fi
fi

if [[ ! -f "$AITEAMFORGE_DIR/iterm2_window_manager.py" && ! -f "$AITEAMFORGE_DIR/scripts/iterm2_window_manager.py" ]]; then
    echo "  ✗ Window manager not found"
    echo "    Fix: aiteamforge setup"
    PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
fi

if [[ $PREFLIGHT_ERRORS -gt 0 ]]; then
    echo ""
    echo "  $PREFLIGHT_ERRORS pre-flight check(s) failed."
    read -p "  Continue anyway? (y/N): " _continue
    [[ "$_continue" != [Yy]* ]] && exit 1
fi

# Resolve window manager path
WM="$AITEAMFORGE_DIR/iterm2_window_manager.py"
[[ ! -f "$WM" ]] && WM="$AITEAMFORGE_DIR/scripts/iterm2_window_manager.py"

# ============================================================================
# Start
# ============================================================================
[[ -t 1 ]] && clear

# ============================================================================
# FIRST: Capture the current iTerm2 window IMMEDIATELY before user can switch.
# This prevents race conditions if the user switches windows during startup.
# Must happen before the banner so there is minimal delay after script launch.
# ============================================================================
if [[ "$TERM_PROGRAM" == "iTerm.app" ]] || pgrep -f "iTerm.app" > /dev/null; then
    echo "  Capturing current window..."
    python3 "$WM" --action init-team-window --window-title "$ITERM_WINDOW_NAME" 2>>"$ITERM_STARTUP_LOG"
    if [[ $? -ne 0 ]]; then
        echo "  Warning: Window capture failed (see $ITERM_STARTUP_LOG)"
    fi
fi

echo "  Cleaning up from previous sessions..."
cleanup_orphans

echo ""
echo "  ${TEAM_NAME}"
echo "   ${TEAM_THEME}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "   LCARS Port:  $LCARS_PORT"
echo "   tmux socket: $TMUX_SOCKET"
echo "   Agents:      ${AGENTS[*]}"
echo ""

# Ensure LCARS Web profile exists in iTerm2
LCARS_PROFILE_SCRIPT="$AITEAMFORGE_DIR/scripts/create-lcars-profile.py"
if [[ -f "$LCARS_PROFILE_SCRIPT" ]]; then
    python3 "$LCARS_PROFILE_SCRIPT" "http://localhost:$LCARS_PORT" 2>/dev/null
fi

# ============================================================================
# LCARS tmux session (created synchronously — used by fleet monitor)
# ============================================================================
LCARS_SESSION="${TEAM_ID}-lcars"
if ! tmux -L "$TMUX_SOCKET" has-session -t "$LCARS_SESSION" 2>/dev/null; then
    echo "  Creating LCARS session: $LCARS_SESSION"
    tmux -L "$TMUX_SOCKET" new-session -d -s "$LCARS_SESSION" \
        -n "lcars" -x 220 -y 50
    tmux -L "$TMUX_SOCKET" send-keys -t "${LCARS_SESSION}:0" \
        "echo 'LCARS Dashboard — http://localhost:${LCARS_PORT}'" C-m
else
    echo "  LCARS session already exists: $LCARS_SESSION"
fi

# ============================================================================
# Pre-initialize agent panel JSON files
# ============================================================================
# Writes <kanban_tmp>/lcars-agent-<team>-<agent>.json for each agent so the
# LCARS agent panel display has real developer/role data from the start.
# Also writes a legacy copy to /tmp/ for use by banner scripts.
# Runs synchronously before session creation; fast (reads persona markdown only).
# ============================================================================
# Resolve init script: installed layout uses scripts/, dev/tap uses share/scripts/
_PANEL_JSON_SCRIPT="$AITEAMFORGE_DIR/scripts/init-agent-panel-json.py"
[[ ! -f "$_PANEL_JSON_SCRIPT" ]] && _PANEL_JSON_SCRIPT="$AITEAMFORGE_DIR/share/scripts/init-agent-panel-json.py"
if [[ -f "$_PANEL_JSON_SCRIPT" ]]; then
    echo "  Pre-initializing agent panel data..."
    python3 "$_PANEL_JSON_SCRIPT" "$TEAM_ID" "$AITEAMFORGE_DIR" 2>/dev/null \
        || echo "  Warning: Agent panel JSON init failed (banner will use fallback values)"
fi

# Resolve the kanban/tmp directory for this team (mirrors lcars-tmp-dir.sh).
# The JSON files written by init-agent-panel-json.py live here; agent-panel-display.sh
# reads from the same location. Falls back to /tmp/ if Python resolution fails.
_KANBAN_TMP=$(python3 -c "
import os, sys
dirs = {
    'academy': os.path.expanduser('~/dev-team/kanban'),
    'ios': '/Users/Shared/Development/Main Event/MainEventApp-iOS/kanban',
    'android': '/Users/Shared/Development/Main Event/MainEventApp-Android/kanban',
    'firebase': '/Users/Shared/Development/Main Event/MainEventApp-Functions/kanban',
    'command': '/Users/Shared/Development/Main Event/dev-team/kanban',
    'mainevent': '/Users/Shared/Development/Main Event/dev-team/kanban',
    'dns': '/Users/Shared/Development/DNSFramework/kanban',
    'freelance': os.path.expanduser('~/dev-team/kanban'),
    'legal-coparenting': os.path.expanduser('~/legal/coparenting/kanban'),
    'finance-personal': os.path.expanduser('~/finance/personal/kanban'),
    'medical': os.path.expanduser('~/medical/general/kanban'),
}
team = '$TEAM_ID'
kanban_dir = dirs.get(team, os.path.expanduser('~/dev-team/kanban'))
tmp_dir = os.path.join(kanban_dir, 'tmp')
try:
    os.makedirs(tmp_dir, exist_ok=True)
    print(tmp_dir)
except Exception:
    print('/tmp')
" 2>/dev/null || echo "/tmp")


# ============================================================================
# Async tmux session initialization
# ============================================================================
# Create tmux sessions in parallel for faster startup.
# Each session gets named windows matching the production pattern:
#   window 0 (cmd)     — main agent command window
#   window 1 (monitor) — monitoring / scratch space
# Sessions are created before opening iTerm2 tabs so attach succeeds.
# ============================================================================
echo "  Creating tmux sessions (async for speed)..."
_tmux_pids=()

for agent in "${AGENTS[@]}"; do
    session_name="${TEAM_ID}-${agent}"
    if tmux -L "$TMUX_SOCKET" has-session -t "$session_name" 2>/dev/null; then
        echo "  Session $session_name already exists — skipping"
        continue
    fi
    echo "  Initializing $session_name..."
    (
        # Resolve per-agent window names from installer-embedded config.
        # Variable name uses underscores (hyphens in agent names are sanitized).
        _agent_key="${agent//-/_}"
        _windows_var="AGENT_WINDOWS_${_agent_key}"
        _windows="${(P)_windows_var}"

        # Parse window names array; fall back to "<agent>-cmd monitor" if not configured
        _win_names=()
        if [[ -n "$_windows" ]]; then
            _win_names=(${(s: :)_windows})
        else
            _win_names=("${agent}-cmd" "monitor")
        fi
        _win0="${_win_names[1]:-${agent}-cmd}"
        _win1="${_win_names[2]:-monitor}"

        # Window 0: main command window (agent-specific name)
        tmux -L "$TMUX_SOCKET" new-session -d -s "$session_name" \
            -n "$_win0" -x 220 -y 50 2>/dev/null

        # Persist session identity variables so kanban helpers and cc aliases
        # work correctly when an agent attaches to this session
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_TYPE    "$TEAM_ID"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_NAME    "$agent"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_CODE    "$session_name"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_DIR     "$TEAM_ID"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" TMUX_SOCKET     "$TMUX_SOCKET"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" AITEAMFORGE_DIR "$AITEAMFORGE_DIR"

        # Export env vars into window 0 and cd to the working directory
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
            "export SESSION_TYPE='${TEAM_ID}' SESSION_NAME='${agent}' SESSION_CODE='${session_name}' SESSION_DIR='${TEAM_ID}' TMUX_SOCKET='${TMUX_SOCKET}' AITEAMFORGE_DIR='${AITEAMFORGE_DIR}'" C-m
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
            "mkdir -p '${TEAM_WORKING_DIR}' 2>/dev/null; cd '${TEAM_WORKING_DIR}' 2>/dev/null || cd \"\$HOME\"" C-m

        # Source the team-specific zshrc to set the LCARS-themed prompt.
        # The file ~/.zshrc_<team>_<agent> contains the prompt definition,
        # division color, and session identity variables.  We source it after
        # exporting SESSION_TYPE so it can safely override the generic prompt
        # that aiteamforge-prompt.sh skips when SESSION_TYPE is already set.
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
            "[[ -f \"\$HOME/.zshrc_${TEAM_ID}_${agent}\" ]] && source \"\$HOME/.zshrc_${TEAM_ID}_${agent}\"" C-m

        # Source the team banner script to display the LCARS agent banner in window 0.
        # A small inline helper reads agent data from the pre-initialized JSON
        # (written by init-agent-panel-json.py) so the banner shows real developer
        # names/roles. Falls back to basic session vars if the JSON is missing.
        local _banner_script="${AITEAMFORGE_DIR}/${TEAM_ID}/scripts/${TEAM_ID}-banner.sh"
        local _agent_json="${_KANBAN_TMP}/lcars-agent-${TEAM_ID}-${agent}.json"
        if [[ -f "$_banner_script" ]]; then
            if [[ -f "$_agent_json" ]]; then
                # Read persona fields from JSON for rich banner display
                local _btheme _bterm _bsdesc _bloc _bdev _brole _btdesc
                _btheme=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('theme','OPERATIONS'))" 2>/dev/null || echo "${TEAM_THEME}")
                _bterm=$(python3  -c "import json; d=json.load(open('$_agent_json')); print(d.get('terminal','${agent}'))" 2>/dev/null || echo "${agent}")
                _bsdesc=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('session_desc',''))" 2>/dev/null || echo "")
                _bloc=$(python3   -c "import json; d=json.load(open('$_agent_json')); print(d.get('location',''))" 2>/dev/null || echo "")
                _bdev=$(python3   -c "import json; d=json.load(open('$_agent_json')); print(d.get('developer',''))" 2>/dev/null || echo "")
                _brole=$(python3  -c "import json; d=json.load(open('$_agent_json')); print(d.get('role',''))" 2>/dev/null || echo "")
                _btdesc=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('terminal_desc',''))" 2>/dev/null || echo "")
                tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
                    "source '${_banner_script}' '${_btheme}' '${TEAM_ID}' '${agent}' '0' '${_bterm}-cmd' '${_bsdesc}' '${_bloc}' '${_bdev}' '${_brole}' '${_btdesc}' '${session_name}'" C-m
            else
                # JSON not available — use basic session vars; banner shows defaults for persona fields
                tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
                    "source '${_banner_script}' '${TEAM_THEME}' '${TEAM_ID}' '${agent}' '0' '${agent}-cmd' '${agent}' '' '' '' '' '${session_name}'" C-m
            fi
        fi

        # Window 1: secondary workspace (agent-specific name, e.g. "monitor", "documentation", "testing")
        tmux -L "$TMUX_SOCKET" new-window -t "$session_name" -n "$_win1"
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:1" \
            "export SESSION_TYPE='${TEAM_ID}' SESSION_NAME='${agent}' SESSION_CODE='${session_name}' SESSION_DIR='${TEAM_ID}' TMUX_SOCKET='${TMUX_SOCKET}' AITEAMFORGE_DIR='${AITEAMFORGE_DIR}'" C-m
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:1" \
            "mkdir -p '${TEAM_WORKING_DIR}' 2>/dev/null; cd '${TEAM_WORKING_DIR}' 2>/dev/null || cd \"\$HOME\"" C-m
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:1" \
            "[[ -f \"\$HOME/.zshrc_${TEAM_ID}_${agent}\" ]] && source \"\$HOME/.zshrc_${TEAM_ID}_${agent}\"" C-m

        # Return focus to window 0 (main command window)
        tmux -L "$TMUX_SOCKET" select-window -t "${session_name}:0"
    ) &
    _tmux_pids+=($!)
    sleep 0.2
done

# Wait for all background session-creation processes to finish
if [[ ${#_tmux_pids[@]} -gt 0 ]]; then
    echo "  Waiting for sessions to initialize..."
    for _pid in "${_tmux_pids[@]}"; do
        wait "$_pid" 2>/dev/null
    done
fi
echo "  All sessions initialized"
echo ""

# ============================================================================
# Start LCARS server
# ============================================================================
echo "  Starting LCARS server on port $LCARS_PORT..."
echo "window.LCARS_TARGET_TEAM = '${TEAM_ID}';" > "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js" 2>/dev/null
echo "window.LCARS_TARGET_SESSION = '${TEAM_ID}-lcars';" >> "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js" 2>/dev/null
# Note: cleanup_orphans() already killed any stale server on this port above

# Log directory for LCARS server stderr — created here so the path is ready before launch.
# Note: log files are not auto-rotated; if disk space is a concern, periodically clear
# $AITEAMFORGE_DIR/logs/lcars-server-*.log (e.g. via logrotate or a cron job).
LCARS_LOG_DIR="$AITEAMFORGE_DIR/logs"
mkdir -p "$LCARS_LOG_DIR"
LCARS_SERVER_LOG="${LCARS_LOG_DIR}/lcars-server-${TEAM_ID}.log"

(cd "$AITEAMFORGE_DIR/lcars-ui" && \
    LCARS_TEAM="$TEAM_ID" LCARS_SESSION_NAME="${TEAM_ID}-lcars" \
    python3 server.py "$LCARS_PORT" > /dev/null 2>>"$LCARS_SERVER_LOG" &)

for i in {1..10}; do
    curl -s "http://localhost:$LCARS_PORT/api/status" > /dev/null 2>&1 && break
    sleep 0.5
done

if curl -s "http://localhost:$LCARS_PORT/api/status" > /dev/null 2>&1; then
    echo "  LCARS server ready: http://localhost:$LCARS_PORT"
else
    echo "  Warning: LCARS server may not have started (check: $LCARS_SERVER_LOG)"
fi

# ============================================================================
# Create iTerm2 tabs
# ============================================================================
echo ""
echo "  Creating terminal tabs..."

if [[ "$TERM_PROGRAM" == "iTerm.app" ]] || pgrep -f "iTerm.app" > /dev/null; then

    # Set the LCARS Web profile URL for the inline browser tab
    LCARS_BROWSER_SCRIPT="$AITEAMFORGE_DIR/scripts/set-lcars-profile-browser.py"
    if [[ -f "$LCARS_BROWSER_SCRIPT" ]]; then
        python3 "$LCARS_BROWSER_SCRIPT" "http://localhost:$LCARS_PORT" 2>/dev/null
    fi

    # LCARS kanban dashboard — prefer iTerm2 inline browser, fall back to system browser
    LCARS_OPENED=false

    if [[ -f "$LCARS_BROWSER_SCRIPT" ]]; then
        echo "  Opening LCARS kanban in iTerm2 tab..."
        _lcars_tab_err=$( python3 "$WM" \
            --action create-tab \
            --window-title "$ITERM_WINDOW_NAME" \
            --profile "LCARS Web" \
            --tab-name "LCARS" \
            --command "export ITERM_TAB_TITLE='LCARS' && tmux -L ${TMUX_SOCKET} attach -t ${TEAM_ID}-lcars" \
            2>&1 )
        _lcars_tab_exit=$?
        if [[ $_lcars_tab_exit -eq 0 ]]; then
            LCARS_OPENED=true
        else
            echo "  Warning: iTerm2 inline browser tab failed (exit $_lcars_tab_exit)" >&2
            if [[ -n "$_lcars_tab_err" ]]; then
                echo "  Reason: $_lcars_tab_err" >&2
            fi
            echo "  Possible causes: 'LCARS Web' profile not in iTerm2, or Python API unavailable." >&2
            echo "  See full log: $ITERM_STARTUP_LOG" >&2
            echo "$_lcars_tab_err" >> "$ITERM_STARTUP_LOG"
        fi
    else
        echo "  Note: LCARS browser script not found — skipping iTerm2 inline browser." >&2
        echo "  (Expected: $LCARS_BROWSER_SCRIPT)" >&2
    fi

    # Fallback: open in system browser
    if [[ "$LCARS_OPENED" != "true" ]]; then
        echo "  Opening LCARS kanban in system browser (Safari/default)..."
        echo "  Tip: Run 'aiteamforge setup' to configure the 'LCARS Web' iTerm2 profile for inline browsing."
        open "http://localhost:$LCARS_PORT" 2>/dev/null
    fi
    sleep 0.3

    # Agent tabs — each tab attaches to its named tmux session.
    # The session was created above in the async init block.
    # Single attempt per agent: if Python API is unavailable the window manager
    # falls back to AppleScript automatically — retrying would create duplicate
    # empty tabs (AppleScript creates a tab even when reporting "failure").
    for agent in "${AGENTS[@]}"; do
        session_name="${TEAM_ID}-${agent}"
        echo "  Opening tab: $agent"
        python3 "$WM" \
            --action create-tab \
            --window-title "$ITERM_WINDOW_NAME" \
            --tab-name "$agent" \
            --command "export ITERM_TAB_TITLE='${agent}' && tmux -L ${TMUX_SOCKET} attach -t ${session_name}" \
            2>>"$ITERM_STARTUP_LOG"
        if [[ $? -ne 0 ]]; then
            echo "    Warning: Tab creation failed for $agent (see $ITERM_STARTUP_LOG)" >&2
        fi
        sleep 0.3
    done

    # Add agent panels to agent tabs
    echo ""
    echo "  Adding agent panels..."
    for agent in "${AGENTS[@]}"; do
        agent_panel_script="$AITEAMFORGE_DIR/scripts/agent-panel-display.sh"
        if [[ -f "$agent_panel_script" ]]; then
            python3 "$WM" \
                --action split-agent-panel \
                --window-title "$ITERM_WINDOW_NAME" \
                --tab-name "$agent" \
                --command "$agent_panel_script ${TEAM_ID}-${agent}" \
                2>>"$ITERM_STARTUP_LOG"
        fi
        sleep 0.3
    done

    # Switch to the first agent tab after all tabs are created
    echo ""
    echo "  Switching to ${AGENTS[1]} tab..."
    python3 "$WM" \
        --action select-tab \
        --window-title "$ITERM_WINDOW_NAME" \
        --tab-name "${AGENTS[1]}" \
        2>>"$ITERM_STARTUP_LOG"
else
    # Terminal.app fallback: attach to each tmux session in a new tab
    echo "  iTerm2 not running — using Terminal.app"
    for agent in "${AGENTS[@]}"; do
        session_name="${TEAM_ID}-${agent}"
        echo "  Opening tab: $agent"
        osascript <<APPLESCRIPT
tell application "Terminal"
    activate
    tell application "System Events"
        tell process "Terminal"
            keystroke "t" using command down
        end tell
    end tell
    delay 0.5
    do script "printf '\\\\033]0;$agent\\\\007' && tmux -L $TMUX_SOCKET attach -t $session_name" in front window
end tell
APPLESCRIPT
        sleep 0.5
    done
fi

# ============================================================================
# Post-startup health checks
# ============================================================================
# Verify critical services started correctly.  Runs after tab creation so the
# user can watch without blocking tab creation.  Non-zero errors are advisory.
# ============================================================================
echo ""
echo "  Running health checks..."
_HEALTH_ERRORS=0

# 1. LCARS server — must respond on /api/status within 3 seconds
if curl -s --max-time 3 "http://localhost:$LCARS_PORT/api/status" > /dev/null 2>&1; then
    echo "    LCARS server    OK  http://localhost:$LCARS_PORT"
else
    echo "    LCARS server    FAIL  port $LCARS_PORT not responding (see: $LCARS_SERVER_LOG)"
    _HEALTH_ERRORS=$((_HEALTH_ERRORS + 1))
fi

# 2. Kanban board — the board data directory must be readable
if [[ -d "$KANBAN_DIR" ]]; then
    echo "    Kanban board    OK  $KANBAN_DIR"
else
    echo "    Kanban board    FAIL  directory not found: $KANBAN_DIR"
    _HEALTH_ERRORS=$((_HEALTH_ERRORS + 1))
fi

# 3. Fleet reporter — optional; warn if not detected.
#    The fleet monitor server (port 3001 by default) is started separately
#    and is not a hard requirement for team operation.
_FLEET_PORT="${AITEAMFORGE_FLEET_PORT:-3001}"
if curl -s --max-time 2 "http://localhost:${_FLEET_PORT}/health" > /dev/null 2>&1 || \
   pgrep -f "fleet.monitor\|fleet-monitor\|fleet_monitor" > /dev/null 2>&1; then
    echo "    Fleet reporter  OK"
else
    echo "    Fleet reporter  not detected (optional — start separately if needed)"
fi

# 4. tmux sessions — verify all agent sessions were created successfully
_MISSING_SESSIONS=()
for agent in "${AGENTS[@]}"; do
    session_name="${TEAM_ID}-${agent}"
    if ! tmux -L "$TMUX_SOCKET" has-session -t "$session_name" 2>/dev/null; then
        _MISSING_SESSIONS+=("$session_name")
    fi
done
if [[ ${#_MISSING_SESSIONS[@]} -eq 0 ]]; then
    echo "    tmux sessions   OK  ${#AGENTS[@]} agent sessions ready"
else
    echo "    tmux sessions   FAIL  missing: ${_MISSING_SESSIONS[*]}"
    _HEALTH_ERRORS=$((_HEALTH_ERRORS + 1))
fi

if [[ $_HEALTH_ERRORS -gt 0 ]]; then
    echo ""
    echo "  $_HEALTH_ERRORS health check(s) failed — review output above before starting work."
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  ${TEAM_NAME} ready!"
echo ""
echo "  Terminals:"
echo "    LCARS  http://localhost:$LCARS_PORT"
for agent in "${AGENTS[@]}"; do
    echo "    $agent"
done
echo ""
echo "  Quick Start:"
echo "    1. Click an agent tab"
echo "    2. Run: claude"
echo "    3. Start working!"
echo ""
echo "  Kanban: kb-list | kb-add | kb-status"
echo ""
echo "  Remote attach (tmux -L ${TMUX_SOCKET}):"
for agent in "${AGENTS[@]}"; do
    echo "    tmux -L ${TMUX_SOCKET} attach -t ${TEAM_ID}-${agent}"
done
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [[ -s "$ITERM_STARTUP_LOG" ]]; then
    echo "  iTerm2 errors logged to: $ITERM_STARTUP_LOG"
fi

echo "${TEAM_NAME} ready!"
