#!/bin/zsh
# {{TEAM_NAME}} Startup Script (Project-Based)
# Auto-generated by aiteamforge installer
# Requires a project identifier to launch

# ============================================================================
# Configuration
# ============================================================================
TEAM_ID="{{TEAM_ID}}"
TEAM_NAME="{{TEAM_NAME}}"
TEAM_THEME="{{TEAM_THEME}}"
AITEAMFORGE_DIR="{{AITEAMFORGE_DIR}}"
BASE_WORKING_DIR="{{TEAM_WORKING_DIR}}"
TMUX_SOCKET="{{TEAM_TMUX_SOCKET}}"
LCARS_PORT="{{TEAM_LCARS_PORT}}"
REQUIRES_CLIENT="{{TEAM_REQUIRES_CLIENT}}"
AGENTS=({{TEAM_TERMINAL_LIST}})

# ============================================================================
# Parameter validation
# ============================================================================
if [[ "$REQUIRES_CLIENT" == "true" ]]; then
    # Freelance-style: requires client + project
    if [[ $# -lt 2 ]]; then
        echo "Usage: $0 <client> <project>"
        echo ""
        echo "Examples:"
        echo "  $0 acme mobile-app"
        echo "  $0 doublenode starwords"
        echo ""
        # List existing client/project directories
        if [[ -d "$BASE_WORKING_DIR" ]]; then
            echo "Existing projects:"
            for client_dir in "$BASE_WORKING_DIR"/*/; do
                [[ ! -d "$client_dir" ]] && continue
                client_name=$(basename "$client_dir")
                for project_dir in "$client_dir"*/; do
                    [[ ! -d "$project_dir" ]] && continue
                    project_name=$(basename "$project_dir")
                    echo "  $0 $client_name $project_name"
                done
            done
        fi
        exit 1
    fi
    CLIENT_ID="$1"
    PROJECT_ID="$2"
    PROJECT_DIR="${BASE_WORKING_DIR}/${CLIENT_ID}/${PROJECT_ID}"
    DISPLAY_NAME="${CLIENT_ID}/${PROJECT_ID}"
else
    # Medical/Legal/Finance-style: requires project only
    if [[ $# -lt 1 ]]; then
        echo "Usage: $0 <project>"
        echo ""
        echo "Examples:"
        echo "  $0 ehlers.darren"
        echo "  $0 smith.jane"
        echo ""
        # List existing project directories
        if [[ -d "$BASE_WORKING_DIR" ]]; then
            echo "Existing projects:"
            for project_dir in "$BASE_WORKING_DIR"/*/; do
                [[ ! -d "$project_dir" ]] && continue
                project_name=$(basename "$project_dir")
                [[ "$project_name" == ".*" ]] && continue
                echo "  $0 $project_name"
            done
        fi
        if [[ -z "$(ls -A "$BASE_WORKING_DIR" 2>/dev/null)" ]]; then
            echo "  (none yet — specify a name to create one)"
        fi
        exit 1
    fi
    PROJECT_ID="$1"
    PROJECT_DIR="${BASE_WORKING_DIR}/${PROJECT_ID}"
    DISPLAY_NAME="$PROJECT_ID"
fi

KANBAN_DIR="${PROJECT_DIR}/kanban"
ITERM_WINDOW_NAME="${DISPLAY_NAME} — ${TEAM_NAME}"
ITERM_STARTUP_LOG="/tmp/${TEAM_ID}-${PROJECT_ID}-startup-iterm2-$(date +%Y%m%d-%H%M%S).log"

# ============================================================================
# Project directory setup
# ============================================================================
if [[ ! -d "$PROJECT_DIR" ]]; then
    echo ""
    echo "📁 Project directory does not exist: $PROJECT_DIR"
    echo ""
    read -p "Create it now? (yes/no) [yes]: " create_dir
    create_dir="${create_dir:-yes}"

    if [[ "$create_dir" != "yes" ]]; then
        echo "Cancelled."
        exit 0
    fi

    echo "  Creating project structure..."
    mkdir -p "${PROJECT_DIR}/develop"
    mkdir -p "${PROJECT_DIR}/kanban"
    mkdir -p "${PROJECT_DIR}/worktrees"
    echo "  ✓ ${PROJECT_DIR}/develop/"
    echo "  ✓ ${PROJECT_DIR}/kanban/"
    echo "  ✓ ${PROJECT_DIR}/worktrees/"

    # Create kanban board
    BOARD_FILE="${KANBAN_DIR}/${TEAM_ID}-board.json"
    if [[ ! -f "$BOARD_FILE" ]]; then
        TEAM_SERIES=$(echo "$TEAM_ID" | tr '[:lower:]' '[:upper:]' | cut -c1-3)
        cat > "$BOARD_FILE" <<BOARDEOF
{
  "team": "${TEAM_ID}",
  "teamName": "${TEAM_NAME} — ${DISPLAY_NAME}",
  "subtitle": "${DISPLAY_NAME}",
  "series": "X${TEAM_SERIES}",
  "organization": "AITEAMFORGE",
  "orgColor": "white",
  "kanbanDir": "${KANBAN_DIR}",
  "lastUpdated": "$(date -u '+%Y-%m-%dT%H:%M:%SZ')",
  "nextId": 1,
  "nextEpicId": 1,
  "nextReleaseId": 1,
  "fleetMonitorUrl": "",
  "terminals": {},
  "activeWindows": [],
  "backlog": [],
  "epics": [],
  "releases": []
}
BOARDEOF
        echo "  ✓ Kanban board created: ${BOARD_FILE}"
    fi

    echo ""
    echo "✅ Project '${DISPLAY_NAME}' created!"
    echo ""
fi

# ============================================================================
# Pre-flight checks
# ============================================================================
PREFLIGHT_ERRORS=0

preflight_check() {
    local name="$1" cmd="$2" fix="$3"
    if ! command -v "$cmd" &>/dev/null; then
        echo "  ✗ $name not found"
        echo "    Fix: $fix"
        PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
    fi
}

preflight_check "python3" "python3" "brew install python@3"

if [[ ! -d "/Applications/iTerm.app" ]]; then
    echo "  ✗ iTerm2 not found"
    echo "    Fix: brew install --cask iterm2"
    PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
fi

if [[ -d "/Applications/iTerm.app" ]]; then
    _api=$(defaults read com.googlecode.iterm2 EnableAPIServer 2>/dev/null || true)
    if [[ "$_api" != "1" ]]; then
        echo "  Enabling iTerm2 Python API..."
        defaults write com.googlecode.iterm2 EnableAPIServer -bool true
        echo "  ⚠ iTerm2 must be restarted for Python API to activate."
        echo "    Please quit and restart iTerm2, then run this script again."
        exit 1
    fi
fi

WM="$AITEAMFORGE_DIR/iterm2_window_manager.py"
[[ ! -f "$WM" ]] && WM="$AITEAMFORGE_DIR/scripts/iterm2_window_manager.py"
if [[ ! -f "$WM" ]]; then
    echo "  ✗ Window manager not found"
    echo "    Fix: aiteamforge setup"
    PREFLIGHT_ERRORS=$((PREFLIGHT_ERRORS + 1))
fi

if [[ $PREFLIGHT_ERRORS -gt 0 ]]; then
    echo ""
    echo "  $PREFLIGHT_ERRORS pre-flight check(s) failed."
    read -p "  Continue anyway? (y/N): " _continue
    [[ "$_continue" != [Yy]* ]] && exit 1
fi

# ============================================================================
# Start
# ============================================================================

# Set LCARS Web profile URL for inline browser tab
LCARS_PROFILE_SCRIPT="$AITEAMFORGE_DIR/scripts/set-lcars-profile-browser.py"
if [[ -f "$LCARS_PROFILE_SCRIPT" ]]; then
    python3 "$LCARS_PROFILE_SCRIPT" "http://localhost:$LCARS_PORT" 2>/dev/null
fi

[[ -t 1 ]] && clear

echo "🚀 ${TEAM_NAME} — ${DISPLAY_NAME}"
echo "   ${TEAM_THEME}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "   Project:     ${DISPLAY_NAME}"
echo "   Dir:         ${PROJECT_DIR}"
echo "   LCARS:       http://localhost:$LCARS_PORT"
echo "   tmux socket: $TMUX_SOCKET"
echo "   Agents:      ${AGENTS[*]}"
echo ""

# Capture iTerm2 window
if pgrep -f "iTerm.app" > /dev/null; then
    echo "  Capturing current window..."
    python3 "$WM" --action init-team-window --window-title "$ITERM_WINDOW_NAME" 2>>"$ITERM_STARTUP_LOG"
fi

# ============================================================================
# LCARS tmux session (created synchronously — used by fleet monitor)
# ============================================================================
LCARS_SESSION="${TEAM_ID}-lcars"
if ! tmux -L "$TMUX_SOCKET" has-session -t "$LCARS_SESSION" 2>/dev/null; then
    echo "  Creating LCARS session: $LCARS_SESSION"
    tmux -L "$TMUX_SOCKET" new-session -d -s "$LCARS_SESSION" \
        -n "lcars" -x 220 -y 50
    tmux -L "$TMUX_SOCKET" send-keys -t "${LCARS_SESSION}:0" \
        "echo 'LCARS Dashboard — http://localhost:${LCARS_PORT}'" C-m
else
    echo "  LCARS session already exists: $LCARS_SESSION"
fi

# ============================================================================
# Pre-initialize agent panel JSON files
# ============================================================================
# Writes /tmp/lcars-agent-<team>-<agent>.json for each agent so the LCARS
# agent panel and banner script have real developer/role data from the start.
# Runs synchronously before session creation; fast (reads persona markdown only).
# ============================================================================
_PANEL_JSON_SCRIPT="$AITEAMFORGE_DIR/share/scripts/init-agent-panel-json.py"
if [[ -f "$_PANEL_JSON_SCRIPT" ]]; then
    echo "  Pre-initializing agent panel data..."
    python3 "$_PANEL_JSON_SCRIPT" "$TEAM_ID" "$AITEAMFORGE_DIR" 2>/dev/null \
        || echo "  Warning: Agent panel JSON init failed (banner will use fallback values)"
fi

# ============================================================================
# Async tmux session initialization
# ============================================================================
# Create tmux sessions in parallel for faster startup.
# Each session gets named windows matching the production pattern:
#   window 0 (cmd)     — main agent command window
#   window 1 (monitor) — monitoring / scratch space
# The tmux session name uses TEAM_ID-AGENT format (e.g. "freelance-command").
# For project-based teams, sessions are scoped to the project by including
# the project/client ID in the tmux session env (SESSION_CODE stays stable).
# Sessions are created before opening iTerm2 tabs so attach succeeds.
# ============================================================================
echo "  Creating tmux sessions (async for speed)..."
_tmux_pids=()

for agent in "${AGENTS[@]}"; do
    session_name="${TEAM_ID}-${agent}"
    if tmux -L "$TMUX_SOCKET" has-session -t "$session_name" 2>/dev/null; then
        echo "  Session $session_name already exists — skipping"
        continue
    fi
    echo "  Initializing $session_name..."
    (
        # Window 0: main command window (cd to project directory)
        tmux -L "$TMUX_SOCKET" new-session -d -s "$session_name" \
            -n "cmd" -x 220 -y 50 2>/dev/null

        # Persist session identity variables so kanban helpers and cc aliases
        # work correctly when an agent attaches to this session
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_TYPE    "$TEAM_ID"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_NAME    "$agent"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_CODE    "$session_name"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" SESSION_DIR     "$TEAM_ID"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" TMUX_SOCKET     "$TMUX_SOCKET"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" AITEAMFORGE_DIR "$AITEAMFORGE_DIR"
        tmux -L "$TMUX_SOCKET" setenv -t "$session_name" PROJECT_DIR     "$PROJECT_DIR"

        # Export env vars into window 0 and cd to the project directory
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
            "export SESSION_TYPE='${TEAM_ID}' SESSION_NAME='${agent}' SESSION_CODE='${session_name}' SESSION_DIR='${TEAM_ID}' TMUX_SOCKET='${TMUX_SOCKET}' AITEAMFORGE_DIR='${AITEAMFORGE_DIR}' PROJECT_DIR='${PROJECT_DIR}'" C-m
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
            "mkdir -p '${PROJECT_DIR}' 2>/dev/null; cd '${PROJECT_DIR}' 2>/dev/null || cd \"\$HOME\"" C-m

        # Source the team banner script to display the LCARS agent banner in window 0.
        # A small inline helper reads agent data from the pre-initialized JSON
        # (written by init-agent-panel-json.py) so the banner shows real developer
        # names/roles. Falls back to basic session vars if the JSON is missing.
        local _banner_script="${AITEAMFORGE_DIR}/${TEAM_ID}/scripts/${TEAM_ID}-banner.sh"
        local _agent_json="/tmp/lcars-agent-${TEAM_ID}-${agent}.json"
        if [[ -f "$_banner_script" ]]; then
            if [[ -f "$_agent_json" ]]; then
                # Read persona fields from JSON for rich banner display
                local _btheme _bterm _bsdesc _bloc _bdev _brole _btdesc
                _btheme=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('theme','OPERATIONS'))" 2>/dev/null || echo "${TEAM_THEME}")
                _bterm=$(python3  -c "import json; d=json.load(open('$_agent_json')); print(d.get('terminal','${agent}'))" 2>/dev/null || echo "${agent}")
                _bsdesc=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('session_desc',''))" 2>/dev/null || echo "")
                _bloc=$(python3   -c "import json; d=json.load(open('$_agent_json')); print(d.get('location',''))" 2>/dev/null || echo "")
                _bdev=$(python3   -c "import json; d=json.load(open('$_agent_json')); print(d.get('developer',''))" 2>/dev/null || echo "")
                _brole=$(python3  -c "import json; d=json.load(open('$_agent_json')); print(d.get('role',''))" 2>/dev/null || echo "")
                _btdesc=$(python3 -c "import json; d=json.load(open('$_agent_json')); print(d.get('terminal_desc',''))" 2>/dev/null || echo "")
                tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
                    "source '${_banner_script}' '${_btheme}' '${TEAM_ID}' '${agent}' '0' '${_bterm}' '${_bsdesc}' '${_bloc}' '${_bdev}' '${_brole}' '${_btdesc}' '${session_name}'" C-m
            else
                # JSON not available — use basic session vars; banner shows defaults for persona fields
                tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:0" \
                    "source '${_banner_script}' '${TEAM_THEME}' '${TEAM_ID}' '${agent}' '0' '${agent}' '${agent}' '' '' '' '' '${session_name}'" C-m
            fi
        fi

        # Window 1: monitoring / scratch space
        tmux -L "$TMUX_SOCKET" new-window -t "$session_name" -n "monitor"
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:1" \
            "export SESSION_TYPE='${TEAM_ID}' SESSION_NAME='${agent}' SESSION_CODE='${session_name}' SESSION_DIR='${TEAM_ID}' TMUX_SOCKET='${TMUX_SOCKET}' AITEAMFORGE_DIR='${AITEAMFORGE_DIR}' PROJECT_DIR='${PROJECT_DIR}'" C-m
        tmux -L "$TMUX_SOCKET" send-keys -t "${session_name}:1" \
            "mkdir -p '${PROJECT_DIR}' 2>/dev/null; cd '${PROJECT_DIR}' 2>/dev/null || cd \"\$HOME\"" C-m

        # Return focus to window 0 (main command window)
        tmux -L "$TMUX_SOCKET" select-window -t "${session_name}:0"
    ) &
    _tmux_pids+=($!)
    sleep 0.2
done

# Wait for all background session-creation processes to finish
if [[ ${#_tmux_pids[@]} -gt 0 ]]; then
    echo "  Waiting for sessions to initialize..."
    for _pid in "${_tmux_pids[@]}"; do
        wait "$_pid" 2>/dev/null
    done
fi
echo "  All sessions initialized"
echo ""

# ============================================================================
# Start LCARS server
# ============================================================================
echo "  Starting LCARS server on port $LCARS_PORT..."
echo "window.LCARS_TARGET_TEAM = '${TEAM_ID}';" > "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js" 2>/dev/null
echo "window.LCARS_TARGET_SESSION = '${TEAM_ID}-lcars';" >> "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js" 2>/dev/null
pkill -f "server.py.*$LCARS_PORT" 2>/dev/null
(cd "$AITEAMFORGE_DIR/lcars-ui" && \
    LCARS_TEAM="$TEAM_ID" LCARS_SESSION_NAME="${TEAM_ID}-lcars" \
    python3 server.py "$LCARS_PORT" > /dev/null 2>&1 &)

for i in {1..10}; do
    curl -s "http://localhost:$LCARS_PORT/api/status" > /dev/null 2>&1 && break
    sleep 0.5
done

if curl -s "http://localhost:$LCARS_PORT/api/status" > /dev/null 2>&1; then
    echo "  LCARS server ready: http://localhost:$LCARS_PORT"
else
    echo "  Warning: LCARS server may not have started"
fi

# ============================================================================
# Create iTerm2 tabs — each tab attaches to its tmux session
# ============================================================================
echo ""
echo "⭐ Creating terminal tabs..."

if pgrep -f "iTerm.app" > /dev/null; then

    # LCARS kanban dashboard — prefer iTerm2 inline browser, fall back to system browser
    LCARS_SETTER="$AITEAMFORGE_DIR/scripts/set-lcars-profile-browser.py"
    LCARS_OPENED=false

    if [[ -f "$LCARS_SETTER" ]]; then
        python3 "$LCARS_SETTER" "http://localhost:$LCARS_PORT" 2>/dev/null

        # Write target team for LCARS auto-redirect
        if [[ -d "$AITEAMFORGE_DIR/lcars-ui" ]]; then
            echo "window.LCARS_TARGET_TEAM = '${TEAM_ID}';" > "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js"
            echo "window.LCARS_TARGET_SESSION = '${TEAM_ID}-lcars';" >> "$AITEAMFORGE_DIR/lcars-ui/lcars-target.js"
        fi

        echo "  Opening LCARS kanban in iTerm2 tab..."
        _lcars_tab_err=$( python3 "$WM" \
            --action create-tab \
            --window-title "$ITERM_WINDOW_NAME" \
            --profile "LCARS Web" \
            --tab-name "LCARS" \
            --command "export ITERM_TAB_TITLE='LCARS' && tmux -L ${TMUX_SOCKET} attach -t ${TEAM_ID}-lcars" \
            2>&1 )
        _lcars_tab_exit=$?
        if [[ $_lcars_tab_exit -eq 0 ]]; then
            LCARS_OPENED=true
        else
            echo "  Warning: iTerm2 inline browser tab failed (exit $_lcars_tab_exit)" >&2
            if [[ -n "$_lcars_tab_err" ]]; then
                echo "  Reason: $_lcars_tab_err" >&2
            fi
            echo "  Possible causes: 'LCARS Web' profile not in iTerm2, or Python API unavailable." >&2
            echo "  See full log: $ITERM_STARTUP_LOG" >&2
            echo "$_lcars_tab_err" >> "$ITERM_STARTUP_LOG"
        fi
    else
        echo "  Note: LCARS browser script not found — skipping iTerm2 inline browser." >&2
        echo "  (Expected: $LCARS_SETTER)" >&2
    fi

    if [[ "$LCARS_OPENED" != "true" ]]; then
        echo "  Opening LCARS kanban in system browser (Safari/default)..."
        echo "  Tip: Run 'aiteamforge setup' to configure the 'LCARS Web' iTerm2 profile for inline browsing."
        open "http://localhost:$LCARS_PORT" 2>/dev/null
    fi
    sleep 0.3

    # Agent tabs — each tab attaches to its named tmux session.
    # Single attempt per agent: if Python API is unavailable the window manager
    # falls back to AppleScript automatically — retrying would create duplicate
    # empty tabs (AppleScript creates a tab even when reporting "failure").
    for agent in "${AGENTS[@]}"; do
        session_name="${TEAM_ID}-${agent}"
        echo "  Opening tab: $agent (tmux session: $session_name)"
        python3 "$WM" \
            --action create-tab \
            --window-title "$ITERM_WINDOW_NAME" \
            --tab-name "$agent" \
            --command "export ITERM_TAB_TITLE='${agent}' && tmux -L ${TMUX_SOCKET} attach -t ${session_name}" \
            2>>"$ITERM_STARTUP_LOG"
        if [[ $? -ne 0 ]]; then
            echo "    Warning: Tab creation failed for $agent (see $ITERM_STARTUP_LOG)" >&2
        fi
        sleep 0.3
    done

    # Agent panels
    echo ""
    echo "🎨 Adding agent panels..."
    for agent in "${AGENTS[@]}"; do
        agent_panel_script="$AITEAMFORGE_DIR/scripts/agent-panel-display.sh"
        if [[ -f "$agent_panel_script" ]]; then
            python3 "$WM" \
                --action split-agent-panel \
                --window-title "$ITERM_WINDOW_NAME" \
                --tab-name "$agent" \
                --command "$agent_panel_script ${TEAM_ID}-${agent}" \
                2>>"$ITERM_STARTUP_LOG"
        fi
        sleep 0.3
    done

    # Switch to the first agent tab
    echo ""
    echo "🎯 Switching to ${AGENTS[0]} tab..."
    python3 "$WM" \
        --action select-tab \
        --window-title "$ITERM_WINDOW_NAME" \
        --tab-name "${AGENTS[0]}" \
        2>>"$ITERM_STARTUP_LOG"
else
    # No iTerm2 — sessions are ready, print attach commands for manual use
    echo "  iTerm2 not running — attach manually with:"
    for agent in "${AGENTS[@]}"; do
        echo "    tmux -L ${TMUX_SOCKET} attach -t ${TEAM_ID}-${agent}"
    done
fi

# ============================================================================
# Summary
# ============================================================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ ${TEAM_NAME} — ${DISPLAY_NAME} ready!"
echo ""
echo "📚 Terminals:"
echo "  * LCARS  — http://localhost:$LCARS_PORT"
for agent in "${AGENTS[@]}"; do
    echo "  • $agent"
done
echo ""
echo "🎯 Quick Start:"
echo "  1. Click an agent tab"
echo "  2. Run: claude"
echo "  3. Start working!"
echo ""
echo "📋 Kanban: kb-list | kb-add | kb-status"
echo ""
echo "🔌 Remote Attach Commands (tmux -L ${TMUX_SOCKET}):"
for agent in "${AGENTS[@]}"; do
    echo "  tmux -L ${TMUX_SOCKET} attach -t ${TEAM_ID}-${agent}"
done
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

if [[ -s "$ITERM_STARTUP_LOG" ]]; then
    echo "  Errors logged to: $ITERM_STARTUP_LOG"
fi

echo "${TEAM_NAME} — ${DISPLAY_NAME} ready!"
